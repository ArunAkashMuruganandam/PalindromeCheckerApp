public class StringComparison {

    /**
     * Checks if a string reads the same forwards and backwards.
     * Demonstrates the two-pointer technique on a char[].
     */
    public static boolean isPalindrome(String str) {
        // Handle edge cases (null or empty strings)
        if (str == null) {
            return false;
        }

        // 1. Convert string to char[]
        // This allows primitive array indexing instead of method calls like charAt()
        char[] charArray = str.toCharArray();

        // 2. Use two-pointer approach
        int left = 0;                        // Start pointer
        int right = charArray.length - 1;    // End pointer

        // Loop until the pointers meet in the middle
        while (left < right) {
            
            // 3. Compare start & end characters
            if (charArray[left] != charArray[right]) {
                // If a mismatch is found, it's not a palindrome
                return false; 
            }
            
            // Move pointers inward for the next comparison
            left++;
            right--;
        }

        // If the loop finishes without mismatches, all characters matched
        return true; 
    }

    public static void main(String[] args) {
        String test1 = "racecar";
        String test2 = "algorithm";

        System.out.println("Is '" + test1 + "' a palindrome? " + isPalindrome(test1));
        System.out.println("Is '" + test2 + "' a palindrome? " + isPalindrome(test2));
    }
}
